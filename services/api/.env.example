# Required
NEON_DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require

# Whisper Graph (public tunnel)
NEO4J_URI=https://neo4j.mostarindustries.com
NEO4J_DATABASE=neo4j
# Leave empty if dbms.security.auth_enabled=false
NEO4J_USER=
NEO4J_PASSWORD=

# Optional
FIRMS_API_KEY=
LOVABLE_API_KEY=

# Service
PORT=8080
NODE_ENV=production
# Comma-separated list of allowed origins (CORS). Leave empty for "*".
ALLOWED_ORIGINS=
